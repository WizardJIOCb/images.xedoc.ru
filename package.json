{
  "name": "images-xedoc-ru",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @images/server --filter @images/web dev",
    "dev:server": "pnpm --filter @images/server dev",
    "dev:web": "pnpm --filter @images/web dev",
    "dev:worker": "pnpm --filter @images/worker dev",
    "db:generate": "pnpm --filter @images/db db:generate",
    "db:push": "pnpm --filter @images/db db:push"
  }
}
